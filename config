[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "main"]
	url = main
	fetch = +refs/heads/*:refs/remotes/main/*
[remote "upstream"]
	url = https://github.com/DevbratPatel/Online-Healthcare-System.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
[remote "origin"]
	url = https://github.com/DevbratPatel/Online-Healthcare-System.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
